generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  STAFF
}

enum MouStatus {
  SIGNED
  PENDING
  NOT_REQUIRED
}

enum ArtworkStatus {
  IN_COLLECTION
  ON_LEASE
  SOLD
}

enum LeaseStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum DocumentRelatedType {
  ARTIST
  CLIENT
}

enum DocumentFileType {
  MOU
  CONTRACT
  CORRESPONDENCE
  OTHER
}

// ---------------------------------------------------------------------------
// Embedded (composite) types
// ---------------------------------------------------------------------------

/// Contact block shared by Artist and Client. Stored inline on the parent.
type ContactInfo {
  email            String?
  phone            String? // local number without country code
  phoneCountryCode String? // e.g. "+91", "+44"
  address          String?
}

/// Structured dimensions — split so the UI can render separate W / H / unit
/// fields instead of a raw string that's easy to input incorrectly.
type Dimensions {
  width  Float
  height Float
  unit   String // "cm" | "in" | "mm"
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String @unique
  passwordHash String
  role         Role   @default(STAFF)

  uploadedDocuments DocumentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Artist {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  bio             String?
  contactInfo     ContactInfo?
  commissionTerms String
  mouStatus       MouStatus    @default(PENDING)

  artworks Artwork[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Artwork {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  medium          String
  dimensions      Dimensions
  year            Int
  acquisitionDate DateTime
  status          ArtworkStatus @default(IN_COLLECTION)
  images          String[]
  notes           String?

  artistId String @db.ObjectId
  artist   Artist @relation(fields: [artistId], references: [id])

  leaseHistory Lease[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([artistId])
  @@index([status])
  @@index([title])
}

model Client {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  contactInfo ContactInfo?
  preferences String?
  notes       String?

  leases Lease[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

/// Join entity that makes Artwork <-> Client relational and drives
/// lease history on both sides.
model Lease {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  startDate DateTime
  endDate   DateTime?
  terms     String?
  status    LeaseStatus @default(ACTIVE)

  artworkId String  @db.ObjectId
  artwork   Artwork @relation(fields: [artworkId], references: [id])

  clientId String @db.ObjectId
  client   Client @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([artworkId])
  @@index([clientId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Stretch goal — build after core modules are complete.
// ---------------------------------------------------------------------------

model DocumentLog {
  id            String              @id @default(auto()) @map("_id") @db.ObjectId
  relatedToType DocumentRelatedType
  relatedToId   String              @db.ObjectId
  fileUrl       String
  fileType      DocumentFileType
  uploadedAt    DateTime            @default(now())

  uploadedBy String @db.ObjectId
  uploader   User   @relation(fields: [uploadedBy], references: [id])

  @@index([relatedToType, relatedToId])
  @@index([uploadedBy])
}
