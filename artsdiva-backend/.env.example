# ---------------------------------------------------------------------------
# ArtsDiva backend environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# MongoDB connection string.
# Prisma's MongoDB connector requires a REPLICA SET (Atlas provides this by
# default; local dev needs mongod started with --replSet).
# Atlas example:
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/artsdiva?retryWrites=true&w=majority"

# JWT session auth
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# HTTP server
PORT=4000
NODE_ENV=development

# Azure Blob Storage — used for artwork images and DocumentLog uploads.
# Connection string is server-side only; never sent to the frontend or
# committed. Rotate the storage account key if it is ever exposed
# (e.g. pasted into a chat, a log, or a public repo).
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER_NAME="images"

# Seed script — creates one initial Admin user (idempotent, skips if exists)
SEED_ADMIN_EMAIL="admin@artsdiva.com"
SEED_ADMIN_PASSWORD="change-me-before-seeding"
SEED_ADMIN_NAME="ArtsDiva Admin"
