# ---------------------------------------------------------------------------
# ArtsDiva backend environment variables
# Copy to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# MongoDB connection string.
# Prisma's MongoDB connector requires a REPLICA SET (Atlas provides this by
# default; local dev needs mongod started with --replSet).
# Atlas example:
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/artsdiva?retryWrites=true&w=majority"

# JWT session auth
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# HTTP server
PORT=4000
NODE_ENV=development

# CORS allow-list — comma-separated list of frontend origins allowed to make
# credentialed requests (scheme + host, no trailing slash). Required in
# production; falls back to reflecting any origin if unset (dev-only).
# Example: "https://artsdiva.bharatbytetech.com,https://<preview>.vercel.app"
FRONTEND_ORIGIN=""

# Auth cookie domain — set this to the shared parent domain of the frontend
# and backend (leading dot), e.g. ".bharatbytetech.com", once the backend is
# put behind a custom domain on that same apex (see docs/DEPLOYMENT.md).
# Leave empty for local dev. Leaving it empty in production degrades to
# SameSite=None cookies, which iOS Safari and Chrome Incognito block —
# that's the "cookie not being set" bug this fixes permanently.
COOKIE_DOMAIN=""

# Azure Blob Storage — used for artwork images and DocumentLog uploads.
# Connection string is server-side only; never sent to the frontend or
# committed. Rotate the storage account key if it is ever exposed
# (e.g. pasted into a chat, a log, or a public repo).
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER_NAME="images"

# Seed script — creates one initial Admin user (idempotent, skips if exists)
SEED_ADMIN_EMAIL="admin@artsdiva.com"
SEED_ADMIN_PASSWORD="change-me-before-seeding"
SEED_ADMIN_NAME="ArtsDiva Admin"
